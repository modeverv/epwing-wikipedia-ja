{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wikiepwing.invalid/schemas/source-lock.schema.json",
  "title": "wikiepwing source.lock.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "provider",
    "project",
    "namespace",
    "snapshot_identifier",
    "snapshot_version",
    "date_modified",
    "downloaded_at",
    "files",
    "supplements",
    "metadata_response_sha256",
    "acquirer"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "namespace": {
      "type": "integer",
      "minimum": 0
    },
    "snapshot_identifier": {
      "type": "string",
      "minLength": 1
    },
    "snapshot_version": {
      "type": "string",
      "minLength": 1,
      "not": {
        "const": "latest"
      }
    },
    "date_modified": {
      "type": "string",
      "format": "date-time"
    },
    "downloaded_at": {
      "type": "string",
      "format": "date-time"
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["relative_path", "chunk_identifier", "size_bytes", "sha256", "media_type"],
        "properties": {
          "relative_path": {
            "type": "string",
            "minLength": 1
          },
          "chunk_identifier": {
            "type": "string",
            "minLength": 1
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "media_type": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "supplements": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "metadata_response_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "acquirer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "git_commit"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "git_commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{4,64}$"
        }
      }
    }
  }
}
