# Wikimedia Enterprise credentials. Copy this file to `.env`, fill in real
# values there, and never commit `.env`. wikiepwing reads these from the
# process environment only; it never writes them to disk or logs them.
#
# Provide either:
#   - WME_USERNAME and WME_PASSWORD together (login), or
#   - WME_ACCESS_TOKEN alone, or
#   - WME_REFRESH_TOKEN alone (used to obtain a new access token)
#
# Priority when acquiring a Snapshot: a valid WME_ACCESS_TOKEN is used first,
# then WME_REFRESH_TOKEN to obtain a new access token, then username/password
# login.

WME_USERNAME=
WME_PASSWORD=
WME_ACCESS_TOKEN=
WME_REFRESH_TOKEN=
